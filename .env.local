# Copy .env.example to .env.local and fill in:

# DATABASE (Critical)
DATABASE_URL="postgresql://user:password@host:5432/chasemycareer"

# NEXTAUTH (Critical)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ENCRYPTION (Critical)
ENCRYPTION_KEY="generate-32-char-random-key"

# OAUTH (Required for social features)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"
LINKEDIN_REDIRECT_URI="http://localhost:3000/api/oauth/linkedin/callback"
INSTAGRAM_CLIENT_ID="your-instagram-client-id"
INSTAGRAM_CLIENT_SECRET="your-instagram-client-secret"
TWITTER_API_KEY="your-twitter-api-key"
TWITTER_API_SECRET="your-twitter-api-secret"
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"

# METRICOOL (Required for analytics)
METRICOOL_API_KEY="your-metricool-api-key"

# QWEN AI (Required for AI features)
QWEN_API_KEY="your-qwen-api-key"

# MEDIA APIs (Required for image generation)
UNSPLASH_ACCESS_KEY="your-unsplash-key"
PEXELS_API_KEY="your-pexels-key"
PIXABAY_API_KEY="your-pixabay-key"

# REDIS (Required for caching & rate limiting)
UPSTASH_REDIS_REST_URL="your-upstash-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# EMAIL (Required for verification & notifications)
RESEND_API_KEY="your-resend-key"
EMAIL_FROM="Chase My Career <noreply@chasemycareer.com>"

# SECURITY (Required)
CRON_SECRET="generate-random-secret"
LINKEDIN_WEBHOOK_SECRET="your-webhook-secret"
INSTAGRAM_WEBHOOK_SECRET="your-webhook-secret"
TWITTER_WEBHOOK_SECRET="your-webhook-secret"
FACEBOOK_WEBHOOK_SECRET="your-webhook-secret"

# MONITORING (Optional but recommended)
SENTRY_DSN="your-sentry-dsn"
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"
NEXT_PUBLIC_POSTHOG_KEY="your-posthog-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# BACKUP (Optional for production)
BACKUP_DIR="/tmp/backups"
S3_BUCKET="your-s3-bucket"
S3_REGION="your-s3-region"
S3_ACCESS_KEY="your-s3-access-key"
S3_SECRET_KEY="your-s3-secret-key"

# APPLICATION
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"