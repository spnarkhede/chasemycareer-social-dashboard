# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://user:password@host:5432/chasemycareer?schema=public"

# ===========================================
# NEXTAUTH
# ===========================================
NEXTAUTH_URL="https://chasemycareer.com"
NEXTAUTH_SECRET="your-32-char-secret-key-here"

# ===========================================
# METRICOOL API
# ===========================================
METRICOOL_API_KEY="your-metricool-api-key"
METRICOOL_API_URL="https://api.metricool.com/v2"
METRICOOL_WEBHOOK_SECRET="your-webhook-secret"

# ===========================================
# SOCIAL PLATFORM APIs
# ===========================================
# LinkedIn
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"
LINKEDIN_REDIRECT_URI="https://chasemycareer.com/api/social/connect/linkedin/callback"

# Instagram/Facebook (Meta)
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
META_REDIRECT_URI="https://chasemycareer.com/api/social/connect/instagram/callback"
META_LONG_LIVED_TOKEN="your-long-lived-token"

# Twitter/X
TWITTER_API_KEY="your-twitter-api-key"
TWITTER_API_SECRET="your-twitter-api-secret"
TWITTER_BEARER_TOKEN="your-twitter-bearer-token"
TWITTER_REDIRECT_URI="https://chasemycareer.com/api/social/connect/twitter/callback"

# TikTok
TIKTOK_CLIENT_KEY="your-tiktok-client-key"
TIKTOK_CLIENT_SECRET="your-tiktok-client-secret"
TIKTOK_REDIRECT_URI="https://chasemycareer.com/api/social/connect/tiktok/callback"

# YouTube
YOUTUBE_CLIENT_ID="your-youtube-client-id"
YOUTUBE_CLIENT_SECRET="your-youtube-client-secret"
YOUTUBE_REDIRECT_URI="https://chasemycareer.com/api/social/connect/youtube/callback"

# ===========================================
# REDIS (Caching & Queues)
# ===========================================
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"
REDIS_URL="redis://your-redis-host:6379"

# ===========================================
# AI (Claude)
# ===========================================
ANTHROPIC_API_KEY="sk-ant-your-api-key"
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ===========================================
# EMAIL (Resend)
# ===========================================
RESEND_API_KEY="re_your-api-key"
EMAIL_FROM="Chase My Career <noreply@chasemycareer.com>"

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
API_RATE_LIMIT_REQUESTS=500
API_RATE_LIMIT_WINDOW=3600

# ===========================================
# CRON SECURITY
# ===========================================
CRON_SECRET="your-cron-secret-key"

# ===========================================
# APPLICATION
# ===========================================
NEXT_PUBLIC_APP_URL="https://chasemycareer.com"
NODE_ENV="production"

# ===========================================
# QWEN AI (Alibaba Cloud DashScope)
# ===========================================
# Get free API key: https://dashscope.console.aliyun.com/
QWEN_API_KEY="sk-your-qwen-api-key"
QWEN_MODEL="qwen-max"
QWEN_BASE_URL="https://dashscope.aliyuncs.com/api/v1"

# ===========================================
# FREE IMAGE/VIDEO APIs
# ===========================================
# Unsplash (Free tier: 50 requests/hour)
# Get key: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY="your-unsplash-key"

# Pexels (Free tier: 20,000 requests/month)
# Get key: https://www.pexels.com/api/
PEXELS_API_KEY="your-pexels-key"

# Pixabay (Free tier: 5,000 requests/hour)
# Get key: https://pixabay.com/api/docs/
PIXABAY_API_KEY="your-pixabay-key"

# ===========================================
# DATABASE & AUTH
# ===========================================
DATABASE_URL="postgresql://user:pass@host:5432/chasemycareer"
NEXTAUTH_SECRET="your-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# REDIS (Caching)
# ===========================================
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# ===========================================
# SOCIAL PLATFORM APIs (for publishing)
# ===========================================
METRICOOL_API_KEY="your-metricool-key"
LINKEDIN_CLIENT_ID="your-linkedin-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-secret"
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-secret"
TWITTER_BEARER_TOKEN="your-twitter-token"


# 1. Get Qwen API Key (Free tier available)
# Visit: https://dashscope.console.aliyun.com/

# 2. Get Free Media API Keys
# Unsplash: https://unsplash.com/developers
# Pexels: https://www.pexels.com/api/
# Pixabay: https://pixabay.com/api/docs/

# 3. Add to .env.local
QWEN_API_KEY="sk-your-key"
UNSPLASH_ACCESS_KEY="your-key"
PEXELS_API_KEY="your-key"
PIXABAY_API_KEY="your-key"

# 4. Run development
npm run dev

# 5. Navigate to
http://localhost:3000/dashboard/ai-content