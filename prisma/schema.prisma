// Add to existing schema

// Link Pages (Like Linktree)
model LinkPage {
  id              String   @id @default(cuid())
  userId          String
  username        String   @unique // e.g., /chasemycareer
  displayName     String
  bio             String?
  avatar          String?
  banner          String?
  theme           String   @default("default")
  backgroundColor String?
  textColor       String?
  font            String   @default("inter")
  isActive        Boolean  @default(true)
  isVerified      Boolean  @default(false)
  customDomain    String?  @unique // e.g., links.chasemycareer.com
  seoTitle        String?
  seoDescription String?
  seoImage        String?
  viewCount       Int      @default(0)
  clickCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  links           Link[]
  socialProfiles  SocialProfile[]
  analytics       LinkAnalytics[]
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([username])
  @@index([userId, isActive])
  @@index([customDomain])
}

// Individual Links on the page
model Link {
  id              String   @id @default(cuid())
  linkPageId      String
  title           String
  url             String
  description     String?
  icon            String?  // Icon name or emoji
  thumbnail       String?
  type            LinkType @default(EXTERNAL)
  category        String?  // e.g., "social", "content", "product"
  order           Int      @default(0)
  isActive        Boolean  @default(true)
  clickCount      Int      @default(0)
  startDate       DateTime? // Schedule link activation
  endDate         DateTime? // Schedule link deactivation
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  linkPage        LinkPage @relation(fields: [linkPageId], references: [id], onDelete: Cascade)
  analytics       LinkAnalytics[]

  @@index([linkPageId, order])
  @@index([linkPageId, isActive])
  @@index([type])
}

enum LinkType {
  EXTERNAL
  EMAIL
  PHONE
  TEXT
  VIDEO
  IMAGE
  FILE
  FORM
}

// Social Media Profiles (displayed on link page)
model SocialProfile {
  id              String   @id @default(cuid())
  linkPageId      String
  platform        String   // linkedin, instagram, twitter, etc.
  username        String
  url             String
  icon            String?
  order           Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  linkPage        LinkPage @relation(fields: [linkPageId], references: [id], onDelete: Cascade)

  @@index([linkPageId, order])
  @@index([platform])
}

// Link Click Analytics
model LinkAnalytics {
  id              String   @id @default(cuid())
  linkPageId      String?
  linkId          String?
  userId          String?
  ipAddress       String?
  userAgent       String?
  referrer        String?
  country         String?
  city            String?
  device          String? // mobile, desktop, tablet
  browser         String?
  os              String?
  clickedAt       DateTime @default(now())
  linkPage        LinkPage? @relation(fields: [linkPageId], references: [id], onDelete: Cascade)
  link            Link?     @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkPageId, clickedAt])
  @@index([linkId, clickedAt])
  @@index([clickedAt])
  @@index([country])
  @@index([device])
}

// Add to User model
model User {
  // ... existing fields
  linkPages       LinkPage[]
}