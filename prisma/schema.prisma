// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Hashed password for credentials auth
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  savedNews     SavedNews[]
  activities    Activity[]
  teamMembers   TeamMember[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

enum Role {
  USER
  ADMIN
  TEAM_MEMBER
}

model Post {
  id            String   @id @default(cuid())
  userId        String
  caption       String
  platforms     String[] // JSON array stored as text
  type          String
  status        String
  scheduledDate DateTime?
  publishedDate DateTime?
  mediaUrl      String?
  tags          String[]
  metadata      Json?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([scheduledDate])
}

model SavedNews {
  id        String   @id @default(cuid())
  userId    String
  newsId    String
  title     String
  url       String
  source    String
  topic     String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, newsId])
  @@index([userId])
}

model Activity {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     TeamMember[]
  projects    Project[]

  @@index([slug])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  joinedAt  DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Project {
  id          String   @id @default(cuid())
  name        String
  teamId      String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tasks       Task[]
}

model Task {
  id          String   @id @default(cuid())
  projectId   String
  assignedTo  String?
  title       String
  description String?
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}


// Add to existing schema
model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  @@index([email])
  @@index([token])
}

model User {
  // Add these fields to existing User model
  emailVerified DateTime?
  emailVerificationToken String? @unique
  emailVerificationExpires DateTime?
}


// Add to User model
model User {
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?  @unique
  twoFactorBackup  String[] // Backup codes
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model User {
  notifications Notification[]
}


model ABTest {
  id          String   @id @default(cuid())
  userId      String
  name        String
  variantA    Json
  variantB    Json
  platforms   String[]
  audience    Json
  duration    Int
  status      String   @default("draft") // draft, running, completed
  startDate   DateTime?
  endDate     DateTime
  winner      String?  // variantA or variantB
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  results     ABTestResult[]
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model ABTestResult {
  id         String   @id @default(cuid())
  abTestId   String
  variant    String   // variantA or variantB
  platform   String
  impressions Int     @default(0)
  engagements Int     @default(0)
  clicks     Int      @default(0)
  shares     Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  abTest     ABTest   @relation(fields: [abTestId], references: [id], onDelete: Cascade)

  @@unique([abTestId, variant, platform])
  @@index([abTestId])
}


// Add to existing schema

// Automation Rules
model AutomationRule {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?
  triggerType     TriggerType
  triggerConfig   Json     // Platform, keywords, post IDs, etc.
  actionType      ActionType
  actionConfig    Json     // Template, delays, conditions
  isActive        Boolean  @default(true)
  priority        Int      @default(0)
  dailyLimit      Int      @default(50)
  sentToday       Int      @default(0)
  lastReset       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  executions      AutomationExecution[]
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([triggerType])
}

enum TriggerType {
  COMMENT
  FOLLOW
  LIKE
  SHARE
  MENTION
  DIRECT_MESSAGE
}

enum ActionType {
  SEND_DM
  SEND_EMAIL
  ADD_TO_SEQUENCE
  TAG_USER
  ADD_TO_CRM
}

// Automation Executions (Log)
model AutomationExecution {
  id              String   @id @default(cuid())
  ruleId          String
  userId          String
  triggerData     Json     // Comment/follower info
  recipientId     String
  recipientName   String
  recipientEmail  String?
  platform        String
  messageSent     String?
  status          ExecutionStatus @default(PENDING)
  errorMessage    String?
  sentAt          DateTime?
  createdAt       DateTime @default(now())
  rule            AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ruleId, status])
  @@index([userId, createdAt])
  @@index([recipientId])
}

enum ExecutionStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  SKIPPED
  OPT_OUT
}

// DM Templates
model DMTemplate {
  id              String   @id @default(cuid())
  userId          String
  name            String
  subject         String?
  content         String   // Supports variables like {{name}}, {{post}}
  variables       String[] // Available variables
  platform        String
  category        String   // welcome, followup, resource, promotion
  isActive        Boolean  @default(true)
  usageCount      Int      @default(0)
  conversionRate  Float?   // Track effectiveness
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([platform, category])
}

// Opt-Out Management
model OptOut {
  id              String   @id @default(cuid())
  userId          String?
  recipientId     String
  recipientEmail  String?
  platform        String
  reason          String?
  createdAt       DateTime @default(now())

  @@unique([recipientId, platform])
  @@index([recipientId])
}

// Message Queue
model MessageQueue {
  id              String   @id @default(cuid())
  userId          String
  platform        String
  recipientId     String
  recipientName   String
  messageContent  String
  templateId      String?
  ruleId          String?
  priority        Int      @default(0)
  status          QueueStatus @default(PENDING)
  scheduledAt     DateTime?
  sentAt          DateTime?
  errorMessage    String?
  retryCount      Int      @default(0)
  maxRetries      Int      @default(3)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, scheduledAt])
  @@index([platform, status])
  @@index([userId, status])
}

enum QueueStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  DELAYED
}

// Add to User model
model User {
  // ... existing fields
  automationRules      AutomationRule[]
  automationExecutions AutomationExecution[]
  dmTemplates          DMTemplate[]
  messageQueue         MessageQueue[]
  optOuts              OptOut[]
}

